{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": false,
    "strict": false,
    "skipLibCheck": true,
  },
  "lib": ["esnext"],
  "include": ["src"],
}
